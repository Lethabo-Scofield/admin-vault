@page "/credentials"
@inject IJSRuntime JS

<PageTitle>API Keys & Credentials | Olyxee Vault</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
        <h2 class="text-xl font-bold text-gray-900">API Keys & Protected Secrets</h2>
        <p class="text-xs text-gray-500">Secure injection matrix for cloud service authorization tokens.</p>
    </div>
    <button class="bg-gray-900 hover:bg-gray-800 text-white text-xs font-semibold px-4 py-2.5 rounded-lg shadow-sm transition-all flex items-center gap-2 self-start sm:self-auto">
        <i data-lucide="plus" class="w-3.5 h-3.5"></i> Provision Secret
    </button>
</div>

<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-gray-50/50">
        <div>
            <h3 class="font-bold text-base text-gray-900">Active Variable Ledger</h3>
            <p class="text-xs text-gray-500">Cryptographically isolated key strings.</p>
        </div>
        <input type="text" placeholder="Filter variables..." class="bg-white border border-gray-200 text-xs px-3 py-1.5 rounded-lg focus:outline-none focus:border-gray-400 w-full sm:w-48 transition-all text-gray-800" />
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase font-semibold tracking-wider border-b border-gray-200 text-[10px]">
                <tr>
                    <th class="px-6 py-3.5">Service & Environment</th>
                    <th class="px-6 py-3.5">Secret Key Value Token</th>
                    <th class="px-6 py-3.5">Scope Owner</th>
                    <th class="px-6 py-3.5 text-right">Actions Workspace</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-gray-700">
                @foreach (var credential in CredentialsList)
                {
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="font-bold text-gray-900">@credential.ServiceName</div>
                            <div class="text-[10px] font-medium flex items-center gap-1 mt-0.5" style="color: @credential.EnvColor">
                                <span class="w-1.5 h-1.5 rounded-full" style="background-color: @credential.BgColor"></span> @credential.Environment
                            </div>
                        </td>
                        <td class="px-6 py-4 font-mono text-gray-600 select-all tracking-tight">
                            <div class="flex items-center gap-2">
                                <span>@(credential.IsRevealed? credential.RawSecretValue: credential.MaskedPlaceholderValue)</span>
                                <button @onclick="() => ToggleSecretReveal(credential)" class="text-gray-400 hover:text-gray-700 transition-colors p-1">
                                    <i data-lucide="@(credential.IsRevealed ? "eye-off" : "eye")" class="w-3.5 h-3.5"></i>
                                </button>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="font-medium text-gray-800">@credential.OwnerEmail</div>
                            <div class="text-[10px] text-gray-400">@credential.Department</div>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="p-1.5 hover:bg-gray-100 rounded-md text-gray-400 hover:text-gray-700 transition-colors">
                                <i data-lucide="edit-3" class="w-3.5 h-3.5"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<VaultKeyModel> CredentialsList = new()
    {
        new VaultKeyModel { ServiceName = "OpenAI API Key", Environment = "Production", EnvColor = "#d97706", BgColor = "#f59e0b", MaskedPlaceholderValue = "sk-proj-••••••••••••w9xA", RawSecretValue = "sk-proj-live-token-value-xyz-12345", OwnerEmail = "siyanda@olyxee.com", Department = "Engineering" },
        new VaultKeyModel { ServiceName = "Supabase DB Password", Environment = "Staging", EnvColor = "#9333ea", BgColor = "#a855f7", MaskedPlaceholderValue = "db-pass-••••••••••••7z9q", RawSecretValue = "db-pass-supabase-cluster-secret-99", OwnerEmail = "system-process", Department = "Infrastructure" }
    };

    private async Task ToggleSecretReveal(VaultKeyModel target)
    {
        target.IsRevealed = !target.IsRevealed;
        await JS.InvokeVoidAsync("refreshTailwindAndIcons");
    }

    public class VaultKeyModel
    {
        public string ServiceName { get; set; } = string.Empty;
        public string Environment { get; set; } = string.Empty;
        public string EnvColor { get; set; } = string.Empty;
        public string BgColor { get; set; } = string.Empty;
        public string MaskedPlaceholderValue { get; set; } = string.Empty;
        public string RawSecretValue { get; set; } = string.Empty;
        public string OwnerEmail { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public bool IsRevealed { get; set; } = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("refreshTailwindAndIcons");
    }
}