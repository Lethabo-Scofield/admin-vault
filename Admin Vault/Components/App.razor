<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <PageTitle>Olyxee Vault</PageTitle>
    <HeadOutlet />

    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@@latest"></script>

    <script>
        window.refreshTailwindAndIcons = function () {
            // 1. Force Lucide to parse brand-new <i data-lucide="..."> nodes
            if (window.lucide && typeof window.lucide.createIcons === 'function') {
                window.lucide.createIcons();
            }

            // 2. Force Tailwind v4 CDN script to re-evaluate the full layout canvas
            // We trick the MutationObserver by changing an arbitrary text node attribute on the core container body element.
            // This immediately triggers a fresh utility compiler compilation pass across all current child layouts.
            document.body.setAttribute('data-render-cycle', Date.now().toString());
        };
    </script>
</head>

<body class="bg-slate-900 text-slate-100 antialiased">
    <Routes @rendermode="InteractiveServer" />

    <script src="_framework/blazor.web.js"></script>
</body>
</html>