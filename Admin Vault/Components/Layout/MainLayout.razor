@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject IJSRuntime JS
@implements IDisposable

<div class="bg-[#f5f5f7] text-gray-800 font-sans antialiased min-h-screen flex w-full">

    @if (sidebarOpen)
    {
        <div class="fixed inset-0 bg-black/30 z-40 lg:hidden animate-ios-in" @onclick="CloseSidebar"></div>
    }

    <aside class="@SidebarClasses">
        <div class="p-6">

            <div class="flex items-center justify-between lg:justify-center gap-4 mb-8 select-none">
                <div class="flex items-center gap-3 lg:flex-col lg:text-center">
                    <div class="p-2 bg-gray-900 rounded-2xl shadow-sm">
                        <img src="Olyxee-White-Logo.png" alt="Olyxee Brandmark" class="w-8 h-8 lg:w-10 lg:h-10 object-contain" />
                    </div>
                    <h1 class="font-bold text-lg lg:text-xl tracking-tight text-gray-950">Olyxee Vault</h1>
                </div>
                <button @onclick="CloseSidebar" class="lg:hidden text-gray-400 hover:text-gray-900 p-1" aria-label="Close menu">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>

            <nav class="space-y-1.5">
                <a href="/" class="@NavClass(IsActive(""))">
                    <i data-lucide="layout-dashboard" class="w-[18px] h-[18px]"></i> Dashboard
                </a>

                <a href="/projects" class="@NavClass(IsSection("projects"))">
                    <i data-lucide="folder" class="w-[18px] h-[18px]"></i> Projects
                </a>

                <a href="/credentials" class="@NavClass(IsActive("credentials"))">
                    <i data-lucide="key-round" class="w-[18px] h-[18px]"></i> API Keys & Credentials
                </a>

                <a href="/compliance" class="@NavClass(IsActive("compliance"))">
                    <i data-lucide="file-text" class="w-[18px] h-[18px]"></i> Documents & Compliance
                </a>

                <a href="/audit-logs" class="@NavClass(IsActive("audit-logs"))">
                    <i data-lucide="history" class="w-[18px] h-[18px]"></i> Audit Logs
                </a>
            </nav>
        </div>

        <div class="p-4 m-3 border border-gray-200/70 rounded-2xl bg-gray-50 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-gray-900 text-white font-bold flex items-center justify-center text-xs">
                    SE
                </div>
                <div>
                    <p class="text-xs font-semibold text-gray-800">Siyanda</p>
                    <p class="text-[10px] text-gray-500">Engineering Lead</p>
                </div>
            </div>
            <button class="text-gray-400 hover:text-rose-600 transition-colors p-1" aria-label="Sign out">
                <i data-lucide="log-out" class="w-4 h-4"></i>
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col min-w-0">
        <header class="h-16 border-b border-gray-200/70 ios-glass px-4 sm:px-8 flex items-center justify-between sticky top-0 z-30 shrink-0">
            <div class="flex items-center gap-3 min-w-0">
                <button @onclick="ToggleSidebar" class="lg:hidden text-gray-700 hover:text-gray-950 p-2 -ml-2 rounded-xl active:bg-gray-100" aria-label="Open menu">
                    <i data-lucide="menu" class="w-5 h-5"></i>
                </button>
                <div class="flex items-center gap-2 overflow-x-auto no-scrollbar">
                    <span class="bg-gray-100 text-[11px] font-semibold px-2.5 py-1 rounded-full text-gray-700 border border-gray-200 whitespace-nowrap">
                        Production
                    </span>
                    <span class="bg-gray-950 text-[11px] font-semibold px-2.5 py-1 rounded-full text-white tracking-wide whitespace-nowrap">
                        Olyxee HQ
                    </span>
                </div>
            </div>
        </header>

        <div class="p-4 sm:p-6 lg:p-8 space-y-8 flex-1 overflow-y-auto">
            <div class="animate-ios-in" @key="currentPageKey">
                @Body
            </div>
        </div>
    </main>
</div>

@code {
    private bool sidebarOpen = false;
    private string currentPageKey = "";

    protected override void OnInitialized()
    {
        currentPageKey = NavManager.Uri;
        NavManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await TriggerUIRefreshAsync();
        }
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebar() => sidebarOpen = false;

    private string SidebarClasses =>
        "fixed lg:static inset-y-0 left-0 z-50 w-72 lg:w-64 bg-white border-r border-gray-200/70 flex flex-col justify-between shrink-0 " +
        "transform transition-transform duration-300 ease-out lg:translate-x-0 " +
        (sidebarOpen ? "translate-x-0 shadow-2xl lg:shadow-none" : "-translate-x-full");

    private string NavClass(bool active) =>
        "flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-colors " +
        (active
            ? "bg-gray-900 text-white font-semibold shadow-sm"
            : "text-gray-600 hover:bg-gray-100 hover:text-gray-950");

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            sidebarOpen = false;
            currentPageKey = e.Location;
            StateHasChanged();

            await Task.Delay(100);
            await TriggerUIRefreshAsync();
        });
    }

    private async Task TriggerUIRefreshAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("refreshTailwindAndIcons");
        }
        catch
        {
            // Context fallbacks for standard pre-render threads
        }
    }

    private bool IsActive(string relativePath)
    {
        var currentUri = NavManager.ToBaseRelativePath(NavManager.Uri).TrimEnd('/');
        return currentUri == relativePath;
    }

    private bool IsSection(string section)
    {
        var currentUri = NavManager.ToBaseRelativePath(NavManager.Uri).TrimEnd('/');
        return currentUri == section || currentUri.StartsWith($"{section}/");
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }
}
