                    <h3 class="font-bold text-sm text-gray-900">Real-Time Audit Trail</h3>
                </div>
                <a href="audit-logs" class="text-xs font-semibold text-gray-500 hover:text-gray-900 transition-colors">View All Logs</a>
            </div>

            <div class="space-y-4">
                <div class="pl-4 border-l-2 border-indigo-500 space-y-1">
                    <div class="flex justify-between items-center text-[11px]">
                        <span class="font-bold text-gray-900 tracking-wide">CREDENTIAL_REVEAL</span>
                        <span class="text-gray-400 font-medium">11:41 AM</span>
                    </div>
                    <p class="text-xs text-gray-600 leading-normal">
                        User <span class="font-medium text-gray-900">siyanda@@olyxee.com</span> revealed OpenAI API key [Prod]
                    </p>
                    <p class="text-[10px] font-mono text-gray-400">IP: 102.65.12.82 • SAST</p>
