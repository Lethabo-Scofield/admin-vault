            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-xs whitespace-nowrap">
                    <thead class="bg-gray-50 text-gray-500 uppercase font-semibold tracking-wider border-b border-gray-200 text-[10px]">
                        <tr>
                            <th class="px-6 py-3.5">Service & Env</th>
                            <th class="px-6 py-3.5">Secret Key Value</th>
                            <th class="px-6 py-3.5">Owner / Role</th>
                            <th class="px-6 py-3.5">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-gray-700">
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-bold text-gray-900">OpenAI API Key</div>
                                <div class="text-[10px] text-amber-600 font-medium flex items-center gap-1 mt-0.5">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> Production
                                </div>
                            </td>
                            <td class="px-6 py-4 font-mono text-gray-500 tracking-tight select-all">sk-proj-••••••••••••w9xA</td>
                            <td class="px-6 py-4">
                                <div class="font-medium text-gray-800">siyanda@@olyxee.com</div>
                                <div class="text-[10px] text-gray-400">Engineering</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="bg-emerald-50 text-emerald-700 text-[10px] font-bold px-2 py-0.5 rounded-md border border-emerald-200">Active</span>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-bold text-gray-900">Supabase DB Password</div>
                                <div class="text-[10px] text-purple-600 font-medium flex items-center gap-1 mt-0.5">
                                    <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span> Staging
                                </div>
                            </td>
                            <td class="px-6 py-4 font-mono text-gray-500 tracking-tight select-all">db-pass-••••••••••••7z9q</td>
                            <td class="px-6 py-4">
                                <div class="font-medium text-gray-800">system-process</div>
                                <div class="text-[10px] text-gray-400">Infrastructure</div>
                            </td>
                            <td class="px-6 py-4">
