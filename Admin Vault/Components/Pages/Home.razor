                    </p>
                    <p class="text-[10px] text-gray-400">Role: Compliance Manager</p>
                </div>
            </div>
        </div>

        <div class="mt-6 p-3 bg-gray-50 border border-gray-200 rounded-xl flex items-center gap-3 text-gray-500 text-center justify-center">
            <i data-lucide="shield" class="w-4 h-4 text-gray-400 shrink-0"></i>
            <span class="text-[11px] font-medium tracking-tight">Logs are historically absolute and un-deletable.</span>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("refreshTailwindAndIcons");
    }
}