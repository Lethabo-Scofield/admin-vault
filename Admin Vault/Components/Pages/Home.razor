<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm flex flex-col justify-between min-h-[110px]">
