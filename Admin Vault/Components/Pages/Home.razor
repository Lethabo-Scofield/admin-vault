    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm flex flex-col justify-between min-h-[110px]">
        <div class="flex justify-between items-start">
            <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider">Audit Triggers (24H)</p>
            <span class="text-indigo-600"><i data-lucide="activity" class="w-4 h-4"></i></span>
